{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1140px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"custom": false,
			"customGradient": false,
			"customDuotone": false,
			"palette": [
				{
					"slug": "base",
					"name": "Base",
					"color": "#ffffff"
				},
				{
					"slug": "contrast",
					"name": "Contrast",
					"color": "#202020"
				},
				{
					"slug": "primary",
					"name": "GPO Green",
					"color": "#2f772f"
				},
				{
					"slug": "secondary",
					"name": "Deep Blue",
					"color": "#0085ae"
				},
				{
					"slug": "leaf",
					"name": "Leaf Green",
					"color": "#75ae55"
				},
				{
					"slug": "sun",
					"name": "Sun Yellow",
					"color": "#f7e16d"
				},
				{
					"slug": "sky",
					"name": "Sky Blue",
					"color": "#52c1db"
				},
				{
					"slug": "alert",
					"name": "Alert Red",
					"color": "#ff1616"
				},
				{
					"slug": "gray",
					"name": "Gray",
					"color": "#666666"
				},
				{
					"slug": "gray-light",
					"name": "Light Gray",
					"color": "#cccccc"
				},
				{
					"slug": "surface",
					"name": "Surface",
					"color": "#f4f5f5"
				}
			]
		},
		"typography": {
			"fluid": true,
			"customFontSize": false,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"slug": "body",
					"name": "Body",
					"fontFamily": "\"AvenirNext LT Pro\", Helvetica, Arial, sans-serif"
				},
				{
					"slug": "mono",
					"name": "Monospace",
					"fontFamily": "SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"name": "Small",
					"size": "0.875rem",
					"fluid": false
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1rem",
					"fluid": false
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.25rem",
					"fluid": {
						"min": "1.125rem",
						"max": "1.25rem"
					}
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "1.75rem",
					"fluid": {
						"min": "1.5rem",
						"max": "1.75rem"
					}
				},
				{
					"slug": "xx-large",
					"name": "Huge",
					"size": "2.5rem",
					"fluid": {
						"min": "2rem",
						"max": "2.5rem"
					}
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"units": ["px", "rem", "%", "vh", "vw"],
			"spacingSizes": [
				{
					"slug": "20",
					"name": "X-Small",
					"size": "0.5rem"
				},
				{
					"slug": "30",
					"name": "Small",
					"size": "1rem"
				},
				{
					"slug": "40",
					"name": "Medium",
					"size": "1.5rem"
				},
				{
					"slug": "50",
					"name": "Large",
					"size": "2.5rem"
				},
				{
					"slug": "60",
					"name": "X-Large",
					"size": "clamp(2.5rem, 6vw, 4rem)"
				},
				{
					"slug": "70",
					"name": "XX-Large",
					"size": "clamp(3.5rem, 10vw, 6.5rem)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.5"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"left": "var(--wp--preset--spacing--30)",
				"right": "var(--wp--preset--spacing--30)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": {
					"radius": "4px"
				},
				"typography": {
					"fontWeight": "700"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
