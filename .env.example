DB_NAME='database_name'
DB_USER='database_user'
DB_PASSWORD='database_password'
DB_HOST='localhost'
DB_HOST='127.0.0.1' # Use if you encounter mysqli 2002 / socket connection issues
DB_PREFIX='wp_'
# In-cluster deployments connect via the Cloud SQL Auth Proxy sidecar, so
# DB_HOST is always 127.0.0.1 there — the proxy handles the real connection.

WP_ENV='development'
WP_HOME='http://example.com'
WP_SITEURL="${WP_HOME}/wp"

# Specify optional debug.log path
# WP_DEBUG_LOG='/path/to/debug.log'

# Generate your keys here: https://roots.io/salts.html
AUTH_KEY='generateme'
SECURE_AUTH_KEY='generateme'
LOGGED_IN_KEY='generateme'
NONCE_KEY='generateme'
AUTH_SALT='generateme'
SECURE_AUTH_SALT='generateme'
LOGGED_IN_SALT='generateme'
NONCE_SALT='generateme'

# Multisite (subdomain install) — required in all non-local environments
DOMAIN_CURRENT_SITE='example.com'

# Object cache (Memorystore Redis). WP_CACHE_KEY_SALT must be unique per
# subsite to avoid key collisions across the network.
REDIS_HOST='127.0.0.1'
REDIS_PORT='6379'
WP_CACHE_KEY_SALT='example.com'

# WP-Stateless media offload to GCS. Not used in local/development — media
# is only offloaded in staging/production (see config/environments/staging.php).
# WP_STATELESS_MEDIA_BUCKET='canopy-staging-media'
# WP_STATELESS_MEDIA_KEY_FILE_PATH='/var/run/secrets/gcs/key.json'
# WP_STATELESS_MEDIA_MODE='stateless'

# WP-Cron is disabled in staging/production (see config/application.php and
# config/environments/development.php) and driven instead by a Kubernetes
# CronJob running `wp cron event run --due-now`. Page-load cron stays on
# for local development.
